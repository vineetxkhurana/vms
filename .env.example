# ─── Copy to .env.local — NEVER commit .env.local ───────────────────────────

# Auth — generate with: openssl rand -base64 32
JWT_SECRET=replace_with_32_char_secret

# Razorpay — https://dashboard.razorpay.com/app/keys
# Use test keys (rzp_test_*) for dev, live keys (rzp_live_*) for prod
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Razorpay Webhook — Dashboard → Settings → Webhooks → secret field
# Required in production; leave blank for local dev (webhook skipped)
RAZORPAY_WEBHOOK_SECRET=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
